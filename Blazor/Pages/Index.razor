@page "/"
@using ReverBlazor.Components
@using ReverBlazor.Models
@using ReverBlazor.Services
@inject PropertyService PropertyService
@inject ArticleService ArticleService

<PageTitle>Rever - Nền tảng bất động sán trực tuyến hàng đầu Việt Nam</PageTitle>

<main class="min-h-screen bg-white">
    {* Hero Search Section *}
    <HeroSearch />
    
    {* Features Section - 4 key benefits *}
    <FeaturesSection />

    {* Buy Properties Section *}
    @if (BuyProperties != null && BuyProperties.Count > 0)
    {
        <PropertiesSection Title="Nhà đất bán mới nhất" Count="14,727" Properties="BuyProperties" />
    }

    {* Divider *}
    <div class="border-t border-gray-200"></div>

    {* Rent Properties Section *}
    @if (RentProperties != null && RentProperties.Count > 0)
    {
        <PropertiesSection Title="Nhà đất cho thuê mới nhất" Count="3,518" Properties="RentProperties" />
    }

    {* CTA Section - Promote Property Posting *}
    <section class="bg-gradient-to-r from-red-50 to-red-100 py-12 md:py-16 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                Có căn hộ hoặc đất cần bán?
            </h2>
            <p class="text-gray-700 text-lg mb-8">
                Đăng tin bất động sán của bạn miễn phí trên Rever ngay hôm nay
            </p>
            <button class="px-8 py-4 bg-red-600 text-white font-bold text-lg rounded-lg hover:bg-red-700 transition">
                Đăng tin ngay
            </button>
        </div>
    </section>

    {* App Download Section - Mobile promotion *}
    <AppDownloadSection />

    {* Recently Viewed Section *}
    <RecentlyViewedSection />

    {* News/Articles Section *}
    <NewsSection />

    {* Location Browse Section - Directory links *}
    <LocationBrowseSection />
</main>

@code {
    private List<Property>? BuyProperties;
    private List<Property>? RentProperties;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load buy properties
            BuyProperties = await PropertyService.GetPropertiesAsync();
            
            // Load rent properties (same data for demo, Claude will implement different logic)
            RentProperties = await PropertyService.GetPropertiesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Error] Loading properties: {ex.Message}");
        }
    }
}
