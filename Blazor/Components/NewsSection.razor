@using ReverBlazor.Services
@using ReverBlazor.Models
@inject ArticleService ArticleService

@* News Section - Thông tin nhà đất *@

<section class="py-16 px-4 sm:px-6 lg:px-8 bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto">
        <div class="mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-3">
                Thông tin nhà đất
            </h2>
            <p class="text-gray-600">
                Tin tức mới nhất, phân tích xu hướng thị trường, cập nhật nhanh chóng và chính xác hàng ngày
            </p>
        </div>
        
        @if (articles != null && articles.Count > 0)
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                {* Featured Article (Left) *}
                <div class="lg:col-span-2">
                    @if (articles.Count > 0)
                    {
                        var featured = articles[0];
                        <div class="rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition bg-gray-900 text-white p-6 h-full flex flex-col justify-between" style="background-image: linear-gradient(135deg, rgba(0,0,0,0.7), rgba(0,0,0,0.9)); background-size: cover;">
                            <div>
                                <h3 class="text-2xl font-bold mb-4 leading-tight">
                                    @featured.Title
                                </h3>
                                <p class="text-gray-300 mb-4 line-clamp-3">
                                    @featured.Description
                                </p>
                            </div>
                            <div class="text-sm text-gray-400">
                                @featured.PublishedDate.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    }
                </div>
                
                {* Article List (Right) *}
                <div class="space-y-4">
                    @foreach (var article in articles.Skip(1).Take(4))
                    {
                        <div class="flex gap-4 pb-4 border-b border-gray-200 hover:bg-gray-50 p-3 rounded transition cursor-pointer">
                            <div class="w-24 h-24 bg-gray-200 rounded flex-shrink-0">
                                @if (!string.IsNullOrEmpty(article.ImageUrl))
                                {
                                    <img src="@article.ImageUrl" alt="@article.Title" class="w-full h-full object-cover rounded">
                                }
                                else
                                {
                                    <div class="w-full h-full bg-gradient-to-br from-gray-300 to-gray-400 flex items-center justify-center">
                                        <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <h4 class="font-bold text-gray-900 line-clamp-2 hover:text-red-600 transition">
                                    @article.Title
                                </h4>
                                <p class="text-sm text-gray-500 mt-2">
                                    @article.PublishedDate.ToString("dd/MM/yyyy")
                                </p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="bg-gray-50 rounded-lg p-8 text-center">
                <p class="text-gray-600">
                    Đang tải tin tức...
                </p>
            </div>
        }
        
        <div class="mt-8">
            <a href="/news" class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold transition">
                Xem thêm bài viết
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>
    </div>
</section>

@code {
    private List<Article>? articles;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            articles = await ArticleService.GetArticlesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading articles: {ex.Message}");
        }
    }
}
