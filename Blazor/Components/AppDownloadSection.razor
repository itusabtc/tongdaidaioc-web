@* App Download Section - Bắt động sán xác thực ngay trong tầm tay *@

<section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            
            {* Left Side - Device Mockups *}
            <div class="relative h-96 lg:h-full flex items-center justify-center">
                {* Decorative dots background *}
                <div class="absolute inset-0 opacity-10">
                    <div style="background-image: radial-gradient(circle, #d32f2f 1px, transparent 1px); background-size: 20px 20px;"></div>
                </div>
                
                {* Device Mockup *}
                <div class="relative z-10 flex gap-4 justify-center scale-75 lg:scale-100 origin-center">
                    {* iPad/Tablet *}
                    <div class="hidden md:flex flex-col">
                        <div class="bg-gray-800 rounded-3xl border-8 border-gray-900 shadow-2xl overflow-hidden w-64 h-80">
                            <div class="bg-gradient-to-b from-gray-700 to-gray-800 h-full flex items-center justify-center">
                                <div class="text-white text-center px-4">
                                    <p class="text-sm font-semibold mb-2">Tìm kiếm nhà đất</p>
                                    <p class="text-xs text-gray-400">Dễ dàng & nhanh chóng</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    {* iPhone *}
                    <div class="flex flex-col">
                        <div class="bg-gray-800 rounded-3xl border-8 border-gray-900 shadow-2xl overflow-hidden w-48 h-96">
                            <div class="bg-gradient-to-b from-gray-700 to-gray-800 h-full flex items-center justify-center">
                                <div class="text-white text-center px-4">
                                    <p class="text-sm font-semibold mb-2">Nhà đất mới</p>
                                    <p class="text-xs text-gray-400">Cập nhật hàng ngày</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            {* Right Side - Content *}
            <div>
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
                    Bắt động sán xác thực ngay trong tầm tay
                </h2>
                
                <p class="text-gray-600 text-lg mb-8 leading-relaxed">
                    Cài đặt ứng dụng Rever trên thiết bị di động để trải nghiệm tìm kiếm nhà đất bán và cho thuê nhanh chóng chống:
                </p>
                
                {* Benefits List *}
                <ul class="space-y-3 mb-8">
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                        </svg>
                        <span class="text-gray-700">An tâm tìm kiếm nhà đất bán và cho thuê nhanh chóng</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                        </svg>
                        <span class="text-gray-700">Xem đầy đủ thông tin tất cả các dự án nội bất</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                        </svg>
                        <span class="text-gray-700">Cập nhật tin mới nhất về thị trường</span>
                    </li>
                </ul>
                
                {* App Store Links *}
                <div class="flex flex-wrap gap-4">
                    <a href="#" class="inline-block transform hover:scale-105 transition">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/a/a9/Amazon_AppStore_badge_English_black.png" alt="App Store" class="h-14">
                    </a>
                    <a href="#" class="inline-block transform hover:scale-105 transition">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/cd/Get_it_on_Google_play.svg" alt="Google Play" class="h-14">
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
