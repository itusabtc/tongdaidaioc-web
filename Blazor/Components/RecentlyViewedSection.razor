@using ReverBlazor.Services
@using ReverBlazor.Models
@inject PropertyService PropertyService

@* Recently Viewed Section - Bạn vừa xem *@

<section class="py-16 px-4 sm:px-6 lg:px-8 bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto">
        <div class="mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-2">
                Bạn vừa xem
            </h2>
            <p class="text-gray-600">
                Những bất động sán gần đây bạn đã tìm hiểu
            </p>
        </div>
        
        @if (recentlyViewed != null && recentlyViewed.Count > 0)
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                @foreach (var property in recentlyViewed.Take(4))
                {
                    <PropertyCard Property="property" />
                }
            </div>
        }
        else
        {
            <div class="bg-gray-50 rounded-lg p-8 text-center">
                <p class="text-gray-600">
                    Bạn chưa xem bất động sán nào gần đây
                </p>
            </div>
        }
        
        <div class="mt-8">
            <a href="/search" class="inline-flex items-center gap-2 text-red-600 hover:text-red-700 font-semibold transition">
                Xem tất cả
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>
    </div>
</section>

@code {
    private List<Property>? recentlyViewed;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            recentlyViewed = await PropertyService.GetPropertiesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading recently viewed: {ex.Message}");
        }
    }
}
